<application
    android:allowBackup="true"
    android:icon="@mipmap/ic_launcher"
    android:label="Мои задания"
    android:theme="@style/Theme.GridnevPavelDmitrievich">

    <activity
        android:name=".MainActivity"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <activity android:name=".CategoryActivity" />
    <activity android:name=".ProductsActivity" />
    <activity android:name=".RecyclerActivity" />
    <activity android:name=".ScrollActivity" />
    <activity android:name=".SpinnerActivity" />
    <activity android:name=".MainDrawerActivity" />
    <activity android:name=".SecondActivityWithBottomBar" />

</application>
